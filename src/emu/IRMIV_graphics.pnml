/*
* LIVERY SELECTION
*/
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMIV_randompurchase_ic_olympic_ovchip) {
	2:  switch_emu_IRMIV_olympic_livery;
    2:  switch_emu_IRMIV_ovchip_livery;
    43: switch_emu_IRMIV_virm_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMIV_randompurchase_ic_olympic) {
	2:  switch_emu_IRMIV_olympic_livery;
    45: switch_emu_IRMIV_virm_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMIV_randompurchase_ic_groen) {
	2:  switch_emu_IRMIV_groen_livery;
    45: switch_emu_IRMIV_virm_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMIV_randompurchase_ic_virmm) {
	2:  switch_emu_IRMIV_groen_livery;
    30: switch_emu_IRMIV_virm_livery;
    15: switch_emu_IRMIV_virmm_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMIV_randompurchase_ic_flow) {
	2:  switch_emu_IRMIV_groen_livery;
    15: switch_emu_IRMIV_virm_livery;
    15: switch_emu_IRMIV_virmm_livery;
    15: switch_emu_IRMIV_flow_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMIV_randompurchase_ic_groen_yellow) {
	2:  switch_emu_IRMIV_groen_livery;
    7: switch_emu_IRMIV_virm_livery;
    7: switch_emu_IRMIV_virmm_livery;
    15: switch_emu_IRMIV_flow_livery;
    8: switch_emu_IRMIV_virm_yellow_livery;
    8: switch_emu_IRMIV_virmm_yellow_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMIV_randompurchase_ic_yellow) {
    15: switch_emu_IRMIV_flow_livery;
    15: switch_emu_IRMIV_virm_yellow_livery;
    15: switch_emu_IRMIV_virmm_yellow_livery;
}
switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_purchaselivery, build_year) {
    0..2001: switch_emu_IRMIV_position;
    2002..2004: switch_emu_IRMIV_virm_livery;
    2010..2011: switch_emu_IRMIV_randompurchase_ic_olympic_ovchip;
    2011..2013: switch_emu_IRMIV_randompurchase_ic_olympic;
    2014..2015: switch_emu_IRMIV_randompurchase_ic_groen;
    2016..2020: switch_emu_IRMIV_randompurchase_ic_virmm;
    2021: switch_emu_IRMIV_randompurchase_ic_flow;
    2022..2025: switch_emu_IRMIV_randompurchase_ic_groen_yellow;
    switch_emu_IRMIV_randompurchase_ic_yellow;
}
switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_autolivery, date_of_last_service) {
    0..2001: switch_emu_IRMIV_position;
    2002..2004: switch_emu_IRMIV_virm_livery;
    2010..2011: switch_emu_IRMIV_randompurchase_ic_olympic_ovchip;
    2011..2013: switch_emu_IRMIV_randompurchase_ic_olympic;
    2014..2015: switch_emu_IRMIV_randompurchase_ic_groen;
    2016..2020: switch_emu_IRMIV_randompurchase_ic_virmm;
    2021: switch_emu_IRMIV_randompurchase_ic_flow;
    2022..2025: switch_emu_IRMIV_randompurchase_ic_groen_yellow;
    switch_emu_IRMIV_randompurchase_ic_yellow;
}

switch(FEAT_TRAINS, PARENT, switch_emu_IRMIV_ic_livery, date_of_last_service) {
    0..date(2001,12,31): switch_emu_IRMIV_position;
    switch_emu_IRMIV_virm_livery;
}

switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_livery, cargo_subtype) {
	1: switch_emu_IRMIV_purchaselivery;
    2: switch_emu_IRMIV_ic_livery;
    3: switch_emu_IRMIV_virm_yellow_livery;
    4: switch_emu_IRMIV_virmm_livery;
    5: switch_emu_IRMIV_virmm_yellow_livery;
    6: switch_emu_IRMIV_flow_livery;
    7: switch_emu_IRMIV_groen_livery;
    8: switch_emu_IRMIV_olympic_livery;
    9: switch_emu_IRMIV_ovchip_livery;
    switch_emu_IRMIV_autolivery;
}

// CARGO SUBTYPE CALLBACK
switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_subtype_text, cargo_subtype) {
    0: return string(str_cargo_subtype_auto);
	1: return string(str_cargo_subtype_purchase);
    2: return string(str_cargo_subtype_virm);
    3: return string(str_cargo_subtype_virm_yellow);
    4: return string(str_cargo_subtype_virmm);
    5: return string(str_cargo_subtype_virmm_yellow);
    6: return string(str_cargo_subtype_ns_flow);
    7: return string(str_cargo_subtype_green);
    8: return string(str_cargo_subtype_olympic);
    9: return string(str_cargo_subtype_ovchip);
    return CB_RESULT_NO_TEXT;
}

/*
* ARTICULATED VEHICLE CALLBACK
*/

switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_articulated, extra_callback_info1) {
    1..3: return item_emu_IRMIV;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

/*
* VEHICLE PROPERTY CALLBACKS
*/

switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_capacity, build_year) {
    0..2001: return 97;
    return 102;
}

switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_weight, build_year) {
    0..2001: return 234;
    return 237;
}

/*
* VISUAL EFFECT AND POWERED CALLBACK
*/

switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_visual_effect_and_powered, (position_in_articulated_veh)) {
    1: return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 0, DISABLE_WAGON_POWER);
    return visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}
