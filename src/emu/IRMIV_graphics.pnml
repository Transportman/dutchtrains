/*
* PURCHASE
*/

spriteset(spriteset_emu_IRMIV_irm_purchase, "gfx/purchase/emu/IRM.png") {
	template_purchase(0, 0)
}
spriteset(spriteset_emu_IRMIV_virm_purchase, "gfx/purchase/emu/VIRM_IV.png") {
	template_purchase(0, 0)
}
spriteset(spriteset_emu_IRMIV_virmm_purchase, "gfx/purchase/emu/VIRM_IV_virmm.png") {
	template_purchase(0, 0)
}
spriteset(spriteset_emu_IRMIV_flow_purchase, "gfx/purchase/emu/VIRM_IV_flow.png") {
	template_purchase(0, 0)
}

switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_purchase, current_year) {
    0..2001: spriteset_emu_IRMIV_irm_purchase;
    2002..2016: spriteset_emu_IRMIV_virm_purchase;
    2017..2021: spriteset_emu_IRMIV_virmm_purchase;
    spriteset_emu_IRMIV_flow_purchase;
}

/*
* VEHICLE
*/

//irm livery
switch(FEAT_TRAINS, SELF, switch_emu_IRMIV_position, (position_in_articulated_veh)) {
	0: spriteset_emu_IRM_front_pantoup;
	3: spriteset_emu_IRM_back_pantodown;
    spriteset_emu_IRM_middle_nopanto;
}

//virm livery
