/*
* LIVERY SELECTION
*/
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMVI_randompurchase_ic_virmm) {
    30: switch_emu_IRMVI_virm_livery;
    15: switch_emu_IRMVI_virmm_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMVI_randompurchase_ic_flow) {
    15: switch_emu_IRMVI_virm_livery;
    15: switch_emu_IRMVI_virmm_livery;
    15: switch_emu_IRMVI_flow_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMVI_randompurchase_ic_flow_yellow) {
    7: switch_emu_IRMVI_virm_livery;
    7: switch_emu_IRMVI_virmm_livery;
    15: switch_emu_IRMVI_flow_livery;
    8: switch_emu_IRMVI_virm_yellow_livery;
    8: switch_emu_IRMVI_virmm_yellow_livery;
}
random_switch(FEAT_TRAINS, PARENT, switch_emu_IRMVI_randompurchase_ic_yellow) {
    15: switch_emu_IRMVI_flow_livery;
    15: switch_emu_IRMVI_virm_yellow_livery;
    15: switch_emu_IRMVI_virmm_yellow_livery;
}
switch(FEAT_TRAINS, SELF, switch_emu_IRMVI_purchaselivery, build_year) {
    0..2015: switch_emu_IRMVI_virm_livery;
    2016..2020: switch_emu_IRMVI_randompurchase_ic_virmm;
    2021: switch_emu_IRMVI_randompurchase_ic_flow;
    2022..2025: switch_emu_IRMVI_randompurchase_ic_flow_yellow;
    switch_emu_IRMVI_randompurchase_ic_yellow;
}
switch(FEAT_TRAINS, SELF, switch_emu_IRMVI_autolivery, date_of_last_service) {
    0..2015: switch_emu_IRMVI_virm_livery;
    2016..2020: switch_emu_IRMVI_randompurchase_ic_virmm;
    2021: switch_emu_IRMVI_randompurchase_ic_flow;
    2022..2025: switch_emu_IRMVI_randompurchase_ic_flow_yellow;
    switch_emu_IRMVI_randompurchase_ic_yellow;
}

switch(FEAT_TRAINS, SELF, switch_emu_IRMVI_livery, cargo_subtype) {
	1: switch_emu_IRMVI_purchaselivery;
    2: switch_emu_IRMVI_virm_livery;
    3: switch_emu_IRMVI_virm_yellow_livery;
    4: switch_emu_IRMVI_virmm_livery;
    5: switch_emu_IRMVI_virmm_yellow_livery;
    6: switch_emu_IRMVI_flow_livery;
    switch_emu_IRMVI_autolivery;
}

// CARGO SUBTYPE CALLBACK
switch(FEAT_TRAINS, SELF, switch_emu_IRMVI_subtype_text, cargo_subtype) {
    0: return string(str_cargo_subtype_auto);
	1: return string(str_cargo_subtype_purchase);
    2: return string(str_cargo_subtype_virm);
    3: return string(str_cargo_subtype_virm_yellow);
    4: return string(str_cargo_subtype_virmm);
    5: return string(str_cargo_subtype_virmm_yellow);
    6: return string(str_cargo_subtype_ns_flow);
    return CB_RESULT_NO_TEXT;
}

/*
* ARTICULATED VEHICLE CALLBACK
*/

switch(FEAT_TRAINS, SELF, switch_emu_IRMVI_articulated, extra_callback_info1) {
    1..5: return item_emu_IRMVI;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

/*
* VISUAL EFFECT AND POWERED CALLBACK
*/

switch(FEAT_TRAINS, SELF, switch_emu_IRMVI_visual_effect_and_powered, (position_in_articulated_veh)) {
    2: return visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 0, DISABLE_WAGON_POWER);
    return visual_effect_and_powered(VISUAL_EFFECT_DISABLE, 0, DISABLE_WAGON_POWER);
}
