/*
* PURCHASE
*/

spriteset(spriteset_emu_IRMVI_virm_purchase, "gfx/purchase/emu/VIRM_VI.png") {
	template_purchase(0, 0)
}
spriteset(spriteset_emu_IRMVI_virmm_purchase, "gfx/purchase/emu/VIRM_VI_virmm.png") {
	template_purchase(0, 0)
}
spriteset(spriteset_emu_IRMVI_flow_purchase, "gfx/purchase/emu/VIRM_VI_flow.png") {
	template_purchase(0, 0)
}

switch(FEAT_TRAINS, SELF, switch_emu_IRMVI_purchase, current_year) {
    0..2016: spriteset_emu_IRMVI_virm_purchase;
    2017..2021: spriteset_emu_IRMVI_virmm_purchase;
    spriteset_emu_IRMVI_flow_purchase;
}


/*
* VEHICLE
*/

//IRM
spriteset(spriteset_emu_IRM_front_pantoup, "gfx/emu/VIRM.png") {
	template_2cc_88(1, 1)
}
spriteset(spriteset_emu_IRM_front_nopanto, "gfx/emu/VIRM.png") {
	template_2cc_88(1, 63)
}
spriteset(spriteset_emu_IRM_front_yellow, "gfx/emu/VIRM.png") {
	template_2cc_88(1, 125)
}
spriteset(spriteset_emu_IRM_back_pantodown, "gfx/emu/VIRM.png") {
	template_2cc_88(1, 32)
}
spriteset(spriteset_emu_IRM_back_nopanto, "gfx/emu/VIRM.png") {
	template_2cc_88(1, 156)
}
spriteset(spriteset_emu_IRM_back_yellow, "gfx/emu/VIRM.png") {
